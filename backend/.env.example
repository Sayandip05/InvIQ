# ── Database ───────────────────────────────────────────────
DATABASE_URL=                             # PostgreSQL (Supabase): postgresql://user:pass@host:5432/dbname (REQUIRED)

# ── Environment ────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ── API Keys ───────────────────────────────────────────────
GROQ_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=smart-inventory-assistant
LANGCHAIN_TRACING_V2=false

# ── Auth & Security ────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Login Lockout ──────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ── Admin Seed (first startup) ─────────────────────────────
ADMIN_EMAIL=admin@inventory.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Administrator

# ── Redis (optional — app works without it) ────────────────
REDIS_URL=                                # e.g. redis://localhost:6379 or Upstash URL

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/minute
